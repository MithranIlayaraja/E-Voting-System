<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color -->
    <solid android:color="@color/yellow"/> <!-- Change to your preferred color -->

    <!-- Rounded corners -->
    <corners android:radius="20dp"/>  <!-- Adjust radius as needed -->

    <!-- Optional border -->
    <stroke
        android:width="2dp"
        android:color="#BDBDBD"/> <!-- Light gray border -->

    <!-- Padding inside -->
    <padding
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp"/>
</shape>
